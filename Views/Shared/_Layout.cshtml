@using DivineImagesATL.Web.Models
@{
    var site = ViewData["SiteContent"] as SiteContent ?? new SiteContent();
    var pageTitle = (ViewData["Title"] as string) ?? site.Brand.Name;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@pageTitle | @site.Brand.Name</title>
    <meta name="description" content="@site.Brand.Tagline" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <div class="container nav-shell">
            <a class="brand" href="/">
                <span class="brand-mark">@site.Brand.LogoText</span>
                <span class="brand-copy">
                    <strong>@site.Brand.Name</strong>
                    <small>@site.Brand.Tagline</small>
                </span>
            </a>

            <nav class="site-nav">
                @foreach (var item in site.Header.NavItems)
                {
                    <a href="@item.Url">@item.Text</a>
                }
            </nav>

            <a class="btn btn-primary btn-sm" href="@site.Header.PrimaryButtonUrl">
                @site.Header.PrimaryButtonText
            </a>
        </div>
    </header>

    <main>
        @RenderBody()
    </main>

    @{
        var footerPhones = (site.Contact.Phone ?? string.Empty)
            .Split('&', StringSplitOptions.RemoveEmptyEntries);

        string ToTelHref(string value)
        {
            return string.IsNullOrWhiteSpace(value)
                ? string.Empty
                : System.Text.RegularExpressions.Regex.Replace(value, @"[^\d+]", string.Empty);
        }
    }

    <footer class="site-footer">
        <section class="footer-top">
            <div class="container footer-top-grid">
                <div class="footer-top-actions">
                    <a class="btn btn-primary" href="/contact-us">Contact Us</a>
                </div>
            </div>
        </section>

        <section class="footer-main">
            <div class="container footer-grid">
                <div class="footer-column">
                    <h3>@site.Brand.Name</h3>
                    <p class="footer-copy">Ultrasound and diagnostic imaging with patient-first care</p>

                    <div class="footer-contact-group">
                        <div class="footer-contact-row">
                            <span class="footer-label">Phone</span>
                            <div class="footer-contact-stack">
                                @if (footerPhones.Length > 0)
                                {
                                    @foreach (var rawPhone in footerPhones)
                                    {
                                        var phone = rawPhone.Trim();

                                        if (!string.IsNullOrWhiteSpace(phone))
                                        {
                                            <a class="footer-contact-link" href="tel:@ToTelHref(phone)">@phone</a>
                                        }
                                    }
                                }
                                else
                                {
                                    <span class="footer-contact-text">Not available</span>
                                }
                            </div>
                        </div>

                        <div class="footer-contact-row">
                            <span class="footer-label">Email</span>
                            <div class="footer-contact-stack">
                                <a class="footer-contact-link" href="mailto:@site.Contact.Email">@site.Contact.Email</a>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(site.Contact.OfficeHours))
                        {
                            <div class="footer-contact-row">
                                <span class="footer-label">Hours</span>
                                <div class="footer-contact-stack">
                                    <span class="footer-contact-text footer-hours">@site.Contact.OfficeHours</span>
                                </div>
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(site.Contact.AddressLine1) || !string.IsNullOrWhiteSpace(site.Contact.AddressLine2))
                        {
                            <div class="footer-contact-row">
                                <span class="footer-label">Service</span>
                                <div class="footer-contact-stack">
                                    @if (!string.IsNullOrWhiteSpace(site.Contact.AddressLine1))
                                    {
                                        <span class="footer-contact-text">@site.Contact.AddressLine1</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(site.Contact.AddressLine2))
                                    {
                                        <span class="footer-contact-text">@site.Contact.AddressLine2</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="footer-column">
                    <h4>Navigation</h4>
                    <ul class="footer-list">
                        @foreach (var item in site.Header.NavItems)
                        {
                            <li><a href="@item.Url">@item.Text</a></li>
                        }
                    </ul>
                </div>

                <div class="footer-column">
                    <h4>We Come to You</h4>
                    <p class="footer-copy">Mobile diagnostic imaging with convenient scheduling and patient-first support.</p>
                    <a class="footer-contact-link" href="/contact-us">Request an appointment</a>
                </div>
            </div>
        </section>

        <section class="footer-bottom">
            <div class="container footer-bottom-row">
                <p>@site.Footer.Copyright</p>
            </div>
        </section>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>