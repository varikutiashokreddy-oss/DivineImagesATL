@model AttorneysPageContent

<section class="page-hero">
    <div class="container narrow">
        <h1>@Model.Hero.Title</h1>
        <p class="lead">@Model.Hero.Subtitle</p>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="cards cards-3">
            @foreach (var stat in Model.Stats)
            {
                <div class="card stat-card">
                    <div class="stat-value">@stat.Value</div>
                    <p>@stat.Label</p>
                </div>
            }
        </div>
    </div>
</section>

<section class="section alt">
    <div class="container">
        <div class="section-heading">
            <h2>Why firms work with us</h2>
        </div>

        <div class="cards cards-3">
            @foreach (var benefit in Model.Benefits)
            {
                <div class="card">
                    <h3>@benefit.Title</h3>
                    <p>@benefit.Description</p>
                </div>
            }
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="section-heading">
            <h2>Three-step referral process</h2>
        </div>

        <div class="cards cards-3">
            @for (var i = 0; i < Model.ProcessSteps.Count; i++)
            {
                var step = Model.ProcessSteps[i];
                <div class="card process-card">
                    <div class="process-number">@(i + 1)</div>
                    <h3>@step.Title</h3>
                    <p>@step.Description</p>
                </div>
            }
        </div>
    </div>
</section>

<section class="section alt">
    <div class="container">
        <div class="card cta-card">
            <div>
                <h2>@Model.BottomCtaTitle</h2>
                <p>@Model.BottomCtaText</p>
            </div>
            <div class="cta-card-actions">
                <a class="btn btn-primary" href="@Model.BottomCtaUrl">Contact Us</a>
            </div>
        </div>
    </div>
</section>