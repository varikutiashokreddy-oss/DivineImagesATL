@model HomePageContent

<section class="hero">
    <div class="container hero-grid">
        <div class="hero-copy">
            <p class="eyebrow">@Model.Hero.Eyebrow</p>
            <h1>@Model.Hero.Title</h1>
            <p class="lead">@Model.Hero.Subtitle</p>

            <div class="actions">
                <a class="btn btn-primary" href="@Model.Hero.PrimaryButtonUrl">@Model.Hero.PrimaryButtonText</a>
                <a class="btn btn-secondary" href="@Model.Hero.SecondaryButtonUrl">@Model.Hero.SecondaryButtonText</a>
            </div>

           @*  <div class="hero-card hero-highlights-card">
                <h3>Why patients choose us</h3>
                <ul class="feature-list">
                    <li>Fast scheduling and responsive support</li>
                    <li>Clear, patient-friendly communication</li>
                    <li>Comfort-focused diagnostic environment</li>
                </ul>
            </div> *@
        </div>

        <div class="hero-media">
            <div class="hero-image-shell">
                <img class="hero-image"
                     src="~/images/ultrasound-room.jpg"
                     alt="Sonographer performing an ultrasound examination in a calm and professional imaging room." />
            </div>
        </div>
    </div>
</section>

<section class="section commitment-section">
    <div class="container">
        <div class="commitment-card">
            <img class="commitment-image"
                 src="~/images/our-commitment.png"
                 alt="Our Commitment to You: experienced sonographers, affordable rates, and quick results." />
        </div>
    </div>
</section>

<section class="section">
    <div class="container split">
        <div class="card">
            <h2>@Model.Insurance.Title</h2>
            <p>@Model.Insurance.Subtitle</p>
            <ul class="feature-list">
                @foreach (var plan in Model.Insurance.AcceptedPlans)
                {
                    <li>@plan</li>
                }
            </ul>
            <p class="muted">@Model.Insurance.SelfPayNote</p>
        </div>

        <div class="card">
            <h2>@Model.Comfort.Title</h2>
            <p>@Model.Comfort.Subtitle</p>
            <ul class="feature-list">
                @foreach (var item in Model.Comfort.Highlights)
                {
                    <li>@item</li>
                }
            </ul>
        </div>
    </div>
</section>
