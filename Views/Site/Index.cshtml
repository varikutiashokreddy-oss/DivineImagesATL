@model HomePageContent

<section class="hero">
    <div class="container hero-grid">
        <div>
            <p class="eyebrow">@Model.Hero.Eyebrow</p>
            <h1>@Model.Hero.Title</h1>
            <p class="lead">@Model.Hero.Subtitle</p>

            <div class="actions">
                <a class="btn btn-primary" href="@Model.Hero.PrimaryButtonUrl">@Model.Hero.PrimaryButtonText</a>
                <a class="btn btn-secondary" href="@Model.Hero.SecondaryButtonUrl">@Model.Hero.SecondaryButtonText</a>
            </div>
        </div>

        <div class="hero-card">
            <h3>Why patients choose us</h3>
            <ul class="feature-list">
                <li>Fast scheduling and responsive support</li>
@*                 <li>Transparent self-pay options</li>
 *@                <li>Clear, patient-friendly communication</li>
                <li>Comfort-focused diagnostic environment</li>
            </ul>
        </div>
    </div>
</section>

