<section class="section">
    <div class="container split">
        <div class="card">
            <h2>@Model.Insurance.Title</h2>
            <p>@Model.Insurance.Subtitle</p>
            <ul class="feature-list">
                @foreach (var plan in Model.Insurance.AcceptedPlans)
                {
                    <li>@plan</li>
                }
            </ul>
            <p class="muted">@Model.Insurance.SelfPayNote</p>
        </div>

        <div class="card">
            <h2>@Model.Comfort.Title</h2>
            <p>@Model.Comfort.Subtitle</p>
            <ul class="feature-list">
                @foreach (var item in Model.Comfort.Highlights)
                {
                    <li>@item</li>
                }
            </ul>
        </div>
    </div>
</section>

