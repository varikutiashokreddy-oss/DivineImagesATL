@model AboutPageContent

<section class="page-hero">
    <div class="container narrow">
        <h1>@Model.Hero.Title</h1>
        <p class="lead">@Model.Hero.Subtitle</p>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="story-blend-card">
            <div class="story-blend-media">
                <img class="story-blend-image"
                     src="~/images/ultrasound-room.jpg"
                     alt="Diagnostic ultrasound care delivered in a calm, patient-focused setting." />
            </div>

            <div class="story-blend-copy">
                <p class="eyebrow">Compassionate imaging, personal care</p>
                <h2>@Model.StoryTitle</h2>
                <p>@Model.Story</p>

                <div class="story-blend-highlights">
                    <div class="story-highlight-pill">Patient-first experience</div>
                    <div class="story-highlight-pill">Clear communication</div>
                    <div class="story-highlight-pill">Dependable diagnostic care</div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section section-tight-top">
    <div class="container">
        <div class="card">
            <h2>Our values</h2>
            <div class="stack">
                @foreach (var value in Model.Values)
                {
                    <div>
                        <h3>@value.Title</h3>
                        <p>@value.Description</p>
                    </div>
                }
            </div>
        </div>
    </div>
</section>