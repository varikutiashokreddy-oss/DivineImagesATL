@model ContactPageViewModel
@{
    var success = TempData["ContactSuccess"] as string;
    var site = ViewData["SiteContent"] as SiteContent ?? new SiteContent();
}

<section class="page-hero">
    <div class="container narrow">
        <h1>@Model.Page.Hero.Title</h1>
        <p class="lead">@Model.Page.Hero.Subtitle</p>
    </div>
</section>

<section class="section">
    <div class="container split contact-split">
        <div class="card">
            <h2>Contact Information</h2>
            <p>@Model.Page.Intro</p>

            <div class="stack">
                <div>
                    <h3>Call Us</h3>
                    <p><a href="tel:@site.Contact.Phone">@site.Contact.Phone</a></p>
                    <p>Fax: @site.Contact.Fax</p>
                </div>

                <div>
                    <h3>Email Us</h3>
                    <p><a href="mailto:@site.Contact.Email">@site.Contact.Email</a></p>
                </div>

                <div>
                    <h3>Visit Us</h3>
                    <p>@site.Contact.AddressLine1</p>
                    <p>@site.Contact.AddressLine2</p>
                    <p>@site.Contact.OfficeHours</p>
                </div>
            </div>
        </div>

        <div class="card">
            <h2>@Model.Page.FormTitle</h2>
            <p>@Model.Page.FormSubtitle</p>

            @if (!string.IsNullOrWhiteSpace(success))
            {
                <div class="alert-success">@success</div>
            }

            <form method="post" asp-action="Index" asp-controller="Contact" class="contact-form">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                <div class="form-grid">
                    <div class="field">
                        <label asp-for="Form.Name"></label>
                        <input asp-for="Form.Name" class="input" />
                        <span asp-validation-for="Form.Name" class="field-error"></span>
                    </div>

                    <div class="field">
                        <label asp-for="Form.Email"></label>
                        <input asp-for="Form.Email" class="input" />
                        <span asp-validation-for="Form.Email" class="field-error"></span>
                    </div>
                </div>

                <div class="field">
                    <label asp-for="Form.Phone"></label>
                    <input asp-for="Form.Phone" class="input" />
                    <span asp-validation-for="Form.Phone" class="field-error"></span>
                </div>

                <div class="field">
                    <label asp-for="Form.Message"></label>
                    <textarea asp-for="Form.Message" class="input textarea" rows="7"></textarea>
                    <span asp-validation-for="Form.Message" class="field-error"></span>
                </div>

                <div class="checkbox-row">
                    <input asp-for="Form.AcceptTerms" />
                    <label asp-for="Form.AcceptTerms">I accept the terms and consent to being contacted.</label>
                </div>
                <span asp-validation-for="Form.AcceptTerms" class="field-error"></span>

                <button type="submit" class="btn btn-primary">Submit Message</button>
            </form>
        </div>
    </div>
</section>
