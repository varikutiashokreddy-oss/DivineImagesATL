﻿@using System.Linq
@model ContactPageViewModel
@{
    var site = ViewData["SiteContent"] as SiteContent ?? new SiteContent();
    var phoneNumbers = (site.Contact.Phone ?? string.Empty)
        .Split('&', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
        .Select(phone => phone.Trim())
        .Where(phone => !string.IsNullOrWhiteSpace(phone))
        .ToList();

    var hasAddress = !string.IsNullOrWhiteSpace(site.Contact.AddressLine1)
        || !string.IsNullOrWhiteSpace(site.Contact.AddressLine2);
}

<section class="page-hero">
    <div class="container narrow">
        <h1>@Model.Page.Hero.Title</h1>
        <p class="lead">@Model.Page.Hero.Subtitle</p>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="contact-page-stack">
            <div class="card contact-intro-card">
                <p class="eyebrow">Contact information</p>
                <h3>Reach Divine Imaging ATL, LLC directly</h3>
@*                 <p>@Model.Page.Intro</p>
 *@            </div>

            <div class="contact-info-grid-enhanced">
                <div class="card contact-info-card-enhanced">
                    <h3>Call Us</h3>
                    <p>Tap a number below to call directly from your phone.</p>

                    <div class="contact-link-list">
                        @if (phoneNumbers.Count > 0)
                        {
                            @foreach (var phone in phoneNumbers)
                            {
                                var telHref = "tel:" + phone
                                    .Replace(" ", string.Empty)
                                    .Replace("(", string.Empty)
                                    .Replace(")", string.Empty)
                                    .Replace("-", string.Empty);

                                <a class="contact-link-button" href="@telHref">@phone</a>
                            }
                        }
                        else
                        {
                            <span class="muted">Phone number coming soon.</span>
                        }
                    </div>
                </div>

                <div class="card contact-info-card-enhanced">
                    <h3>Email Us</h3>
                    <p>Send us a message and we will respond as soon as possible.</p>

                    @if (!string.IsNullOrWhiteSpace(site.Contact.Email))
                    {
                        <a class="contact-link-button" href="mailto:@site.Contact.Email">@site.Contact.Email</a>
                    }
                    else
                    {
                        <span class="muted">Email address coming soon.</span>
                    }
                </div>

                <div class="card contact-info-card-enhanced">
                    <h3>Office Hours</h3>
                    <p class="contact-info-text">@site.Contact.OfficeHours</p>
                </div>

                @if (hasAddress)
                {
                    <div class="card contact-info-card-enhanced">
                        <h3>Visit Us</h3>

                        @if (!string.IsNullOrWhiteSpace(site.Contact.AddressLine1))
                        {
                            <p class="contact-info-text">@site.Contact.AddressLine1</p>
                        }

                        @if (!string.IsNullOrWhiteSpace(site.Contact.AddressLine2))
                        {
                            <p class="contact-info-text">@site.Contact.AddressLine2</p>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</section>